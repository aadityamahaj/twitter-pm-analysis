# ============================================================
# FlightScout Environment Variables
# Copy this file to frontend/.env.local and ml-backend/.env
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- ML Backend ---
# URL where the FastAPI ML service is running
NEXT_PUBLIC_ML_API_URL=http://localhost:8000
# Internal ML API secret (used for /train-model endpoint)
ML_API_SECRET=change-me-in-production

# --- Email (Resend) ---
# Get your key at https://resend.com
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=alerts@flightscout.app

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Flight Data APIs (add when ready to replace mock data) ---
# Choose a provider by setting FLIGHT_API_PROVIDER to one of:
# mock | amadeus | duffel | kiwi | serpapi | aviationstack

FLIGHT_API_PROVIDER=mock

# Amadeus (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Duffel (https://duffel.com/docs/api)
DUFFEL_API_KEY=

# Kiwi/Tequila (https://tequila.kiwi.com)
KIWI_API_KEY=

# SerpAPI Google Flights (https://serpapi.com/google-flights-api)
SERPAPI_KEY=

# AviationStack (https://aviationstack.com)
AVIATIONSTACK_KEY=

# --- ML Backend (Python) ---
MODEL_PATH=models/price_predictor.pkl
DATA_PATH=data/mock_historical.parquet
CORS_ORIGINS=http://localhost:3000,https://flightscout.app
